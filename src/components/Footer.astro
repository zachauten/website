---
import { sanityClient } from "sanity:client";
import { type SocialMedia } from "../sanity/schemaTypes/socialMedia";

interface Props {
  socialMediaItems?: SocialMedia[];
}

const { socialMediaItems: socialMediaFromProps } = Astro.props as Props;

const socialMediaItems = socialMediaFromProps
  ?? await sanityClient.fetch<SocialMedia[]>(
    `*[_type == "socialMedia"] | order(order asc) {
      platform,
      label,
      url,
      emoji,
      order
    }`,
  );
---

<footer class="site-footer">
  <div class="footer-accent" aria-hidden="true"></div>
  <div class="container">
    <div class="footer-content">
      <div class="footer-section footer-brand">
        <h3>NC Triangle DSA</h3>
        <p>Building a democratic, socialist future in the Tar Heel State.</p>
      </div>
      <div class="footer-section">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/#about">About</a></li>
          <li><a href="/#campaigns">Campaigns</a></li>
          <li><a href="/endorsements">Endorsements</a></li>
          <li><a href="/calendar">Events</a></li>
          <li><a href="/#join">Join DSA</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4>Connect</h4>
        <ul>
          {socialMediaItems.map((item) => {
            const isExternal = item.url.startsWith("http://")
              || item.url.startsWith("https://");

            return (
              <li>
                <a
                  href={item.url}
                  target={isExternal ? "_blank" : undefined}
                  rel={isExternal ? "noopener noreferrer" : undefined}
                >
                  {item.platform}
                  {isExternal && (
                    <svg
                      class="footer-external-icon"
                      width="11"
                      height="11"
                      viewBox="0 0 12 12"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      aria-hidden="true"
                    >
                      <path d="M4.5 1.5H10.5V7.5M10.5 1.5L1.5 10.5" />
                    </svg>
                  )}
                  <span
                    class="sr-only"
                  >{isExternal ? " (opens in new tab)" : ""}</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>
        &copy; {new Date().getFullYear()} North Carolina Democratic Socialists
        of America
      </p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--black-rich);
  color: var(--text-on-dark);
  padding: var(--space-3xl) 0 var(--space-lg);
  margin-top: 0;
  position: relative;
}

.footer-accent {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--red-primary);
}

.footer-content {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: var(--space-2xl);
  margin-bottom: var(--space-2xl);
}

.footer-section h3 {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  color: var(--white);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: var(--space-sm);
}

.footer-section h4 {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  color: var(--red-primary);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: var(--space-md);
}

.footer-section p {
  color: var(--gray-400);
  line-height: 1.6;
  max-width: 35ch;
}

.footer-section ul {
  list-style: none;
  padding: 0;
}

.footer-section ul li {
  margin-bottom: var(--space-xs);
}

.footer-section a {
  color: var(--gray-200);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
  display: inline-flex;
  align-items: center;
  gap: var(--space-2xs);
  font-size: var(--text-sm);
}

.footer-section a:hover {
  color: var(--red-primary);
  text-decoration: none;
}

.footer-external-icon {
  opacity: 0.5;
}

.footer-bottom {
  border-top: 1px solid var(--gray-700);
  padding-top: var(--space-lg);
  text-align: center;
}

.footer-bottom p {
  color: var(--gray-500);
  font-size: var(--text-sm);
  max-width: none;
  margin: 0 auto;
}

@media (max-width: 768px) {
  .footer-content {
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  .footer-brand {
    text-align: center;
  }

  .footer-brand p {
    max-width: none;
  }
}
</style>
