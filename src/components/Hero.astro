---
import { Image } from "astro:assets";
import heroImage from "../assets/hero.webp";

interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <Image
      src={heroImage}
      alt=""
      class="hero-bg-image"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </div>
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title animate-in">{title}</h1>
      <p class="hero-subtitle animate-in animate-in-delay-1">
        {subtitle}
      </p>
      <div class="hero-buttons animate-in animate-in-delay-2">
        <a href="#join" class="btn btn--secondary">Become a Member</a>
        <a href="#about" class="btn btn--outline">Learn More</a>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  color: var(--white);
  padding: var(--space-5xl) 0 calc(var(--space-5xl) + 40px);
  text-align: center;
  overflow: hidden;
  clip-path: polygon(0 0, 100% 0, 100% calc(100% - 50px), 0 100%);
}

.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero-bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.38);
}

.hero-bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.hero .container {
  position: relative;
  z-index: 1;
}

.hero-content {
  max-width: 850px;
  margin: 0 auto;
}

.hero-title {
  font-size: clamp(var(--text-4xl), 8vw, var(--text-5xl));
  line-height: 0.95;
  letter-spacing: 0.04em;
  margin-bottom: var(--space-lg);
  color: var(--white);
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
}

.hero-subtitle {
  font-family: var(--font-body);
  font-size: clamp(var(--text-md), 2.5vw, var(--text-lg));
  line-height: 1.5;
  max-width: 600px;
  margin: 0 auto var(--space-xl);
  color: rgba(255, 255, 255, 0.92);
}

.hero-buttons {
  display: flex;
  gap: var(--space-md);
  justify-content: center;
  flex-wrap: wrap;
}

@media (max-width: 768px) {
  .hero {
    padding: var(--space-3xl) 0 calc(var(--space-3xl) + 30px);
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 30px), 0 100%);
  }

  .hero-buttons {
    flex-direction: column;
    align-items: center;
  }

  .hero-buttons .btn {
    width: 100%;
    max-width: 280px;
  }
}
</style>
