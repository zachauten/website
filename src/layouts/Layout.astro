---
import { sanityClient } from "sanity:client";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import type { SocialMedia } from "../sanity/schemaTypes/socialMedia";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const socialMediaItems = await sanityClient.fetch<SocialMedia[]>(
  `*[_type == "socialMedia"] | order(order asc) {
    platform,
    label,
    url,
    emoji,
    order
  }`,
);

const {
  title = "North Carolina DSA",
  description =
    "North Carolina Chapter of the Democratic Socialists of America - Building a democratic, socialist future in the Tar Heel State",
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site ?? "https://www.dsanc.org",
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ec1f27" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="NC Triangle DSA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Preload critical fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <slot />
    <Footer socialMediaItems={socialMediaItems} />
  </body>
</html>
