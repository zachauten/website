---
import CalendarEmbed from "../components/CalendarEmbed";
import Layout from "../layouts/Layout.astro";

const icalFeedUrl = import.meta.env.PUBLIC_ICAL_FEED_URL;
const hasCalendarFeed = Boolean(icalFeedUrl);
const subscribeUrl = icalFeedUrl?.replace(/^https?:\/\//, "webcal://") ?? "";
const calendarDataUrl = "/api/calendar.ics";
---

<Layout
  title="Calendar - North Carolina DSA"
  description="Upcoming events, meetings, and actions from the North Carolina Democratic Socialists of America"
>
  <main id="main-content">
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="container">
        <h1>Upcoming Events</h1>
        <p class="page-hero-sub">
          Join us for meetings, actions, social events, and more!
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        {!hasCalendarFeed && (
          <div class="notice" role="alert">
            <svg
              class="notice-icon"
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <circle cx="9" cy="9" r="7.5" />
              <path d="M9 5.5v4M9 12.5h.01" />
            </svg>
            <p>
              <strong>Note:</strong> Calendar feed is not configured. Set
              <code>PUBLIC_ICAL_FEED_URL</code> in your environment to show
              events.
            </p>
          </div>
        )}

        {hasCalendarFeed ? (
          <div class="calendar-wrapper card card--elevated">
            <CalendarEmbed icalUrl={calendarDataUrl} client:load />
          </div>
        ) : (
           <div class="no-events">
             <p>
               No calendar feed is available right now. Check back soon or
               follow us on social media for announcements.
             </p>
           </div>
         )}

        <div class="calendar-info card card--elevated">
          <h2>Stay Updated</h2>
          <p>Don't miss an event! Here are ways to stay in the loop:</p>
          <ul class="info-list">
            <li>
              <svg
                class="info-icon"
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <rect x="2" y="3" width="12" height="11" rx="2" />
                <path d="M2 6h12M5.5 1v3M10.5 1v3" />
              </svg>
              <a href="#contact">Sign up for our email list</a>
            </li>
            <li>
              <svg
                class="info-icon"
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <circle cx="8" cy="8" r="6" />
                <path d="M8 4v4l3 2" />
              </svg>
              {hasCalendarFeed ? (
                <a href={subscribeUrl}>Subscribe to our calendar</a>
              ) : <>Calendar subscription available soon</>}
            </li>
          </ul>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
.page-hero {
  background: linear-gradient(
    160deg,
    var(--red-primary) 0%,
    var(--red-dark) 50%,
    var(--red-darker) 100%
  );
  color: var(--white);
  padding: var(--space-3xl) 0;
  text-align: center;
  position: relative;
  overflow: hidden;
  clip-path: polygon(0 0, 100% 0, 100% calc(100% - 30px), 0 100%);
}

.page-hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 40px,
    rgba(0, 0, 0, 0.04) 40px,
    rgba(0, 0, 0, 0.04) 42px
  );
  pointer-events: none;
}

.page-hero h1 {
  color: var(--white);
  position: relative;
}

.page-hero-sub {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  color: rgba(255, 255, 255, 0.9);
  max-width: 500px;
  margin: 0 auto;
  position: relative;
}

.notice {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  background: var(--notice-bg);
  border: 1px solid var(--notice-border);
  border-radius: var(--radius-md);
  padding: var(--space-md) var(--space-lg);
  margin-bottom: var(--space-xl);
}

.notice-icon {
  flex-shrink: 0;
  color: var(--notice-border);
  margin-top: 2px;
}

.notice code {
  background: var(--white);
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-sm);
  font-size: 0.9em;
}

.no-events {
  text-align: center;
  padding: var(--space-3xl) 0;
  color: var(--text-secondary);
}

.calendar-wrapper {
  padding: var(--space-lg);
  margin-bottom: var(--space-2xl);
}

.calendar-wrapper.card--elevated {
  transition: none;
}

.calendar-wrapper.card--elevated:hover {
  transform: none;
  box-shadow: var(--shadow-sm);
}

.calendar-wrapper :global(.fc) {
  font-family: var(--font-body);
}

.calendar-wrapper :global(.fc .fc-button) {
  background: var(--red-primary);
  border-color: var(--red-primary);
}

.calendar-wrapper :global(.fc .fc-button:hover),
.calendar-wrapper :global(.fc .fc-button:focus) {
  background: var(--red-dark);
  border-color: var(--red-dark);
}

.calendar-wrapper
  :global(.fc .fc-button-primary:not(:disabled).fc-button-active) {
  background: var(--red-darker);
  border-color: var(--red-darker);
}

.calendar-wrapper :global(.fc .fc-daygrid-event),
.calendar-wrapper :global(.fc .fc-list-event-title a) {
  color: var(--red-darker);
}

.calendar-wrapper :global(.fc .fc-daygrid-event),
.calendar-wrapper :global(.fc .fc-list-event) {
  cursor: pointer;
}

.calendar-wrapper :global(.calendar-modal-backdrop) {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-lg);
  background: rgba(0, 0, 0, 0.65);
}

.calendar-wrapper :global(.calendar-modal) {
  position: relative;
  width: min(680px, 100%);
  max-height: min(85vh, 860px);
  overflow: auto;
  background: var(--white);
  color: var(--text-primary);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-xl);
  padding: var(--space-xl);
  border-top: 6px solid var(--red-primary);
}

.calendar-wrapper :global(.calendar-modal-close) {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  width: 2rem;
  height: 2rem;
  border: none;
  background: transparent;
  color: var(--gray-500);
  font-size: 1.75rem;
  line-height: 1;
  cursor: pointer;
}

.calendar-wrapper :global(.calendar-modal-close:hover) {
  color: var(--red-primary);
}

.calendar-wrapper :global(.calendar-modal-title) {
  margin: 0 2.25rem var(--space-md) 0;
  color: var(--red-primary);
  font-size: clamp(var(--text-xl), 2vw, var(--text-2xl));
  line-height: 1.1;
}

.calendar-wrapper :global(.calendar-modal-meta) {
  margin: 0 0 var(--space-sm);
  color: var(--gray-700);
}

.calendar-wrapper :global(.calendar-modal-meta strong) {
  color: var(--gray-900);
}

.calendar-wrapper :global(.calendar-modal-description) {
  margin-top: var(--space-lg);
}

.calendar-wrapper :global(.calendar-modal-description p) {
  margin: 0 0 var(--space-md);
  max-width: none;
  white-space: pre-wrap;
  color: var(--text-primary);
}

.calendar-wrapper :global(.calendar-modal-actions) {
  margin-top: var(--space-lg);
  margin-bottom: 0;
}

.calendar-info {
  padding: var(--space-xl);
  margin-top: var(--space-2xl);
}

.calendar-info h2 {
  color: var(--red-primary);
  font-size: var(--text-2xl);
  margin-bottom: var(--space-sm);
}

.calendar-info p {
  max-width: none;
}

.info-list {
  list-style: none;
  margin-top: var(--space-md);
  padding: 0;
}

.info-list li {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) 0;
  font-size: var(--text-md);
}

.info-icon {
  color: var(--red-primary);
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .page-hero {
    padding: var(--space-2xl) 0;
  }

  .calendar-wrapper :global(.calendar-modal-backdrop) {
    padding: var(--space-md);
  }

  .calendar-wrapper :global(.calendar-modal) {
    padding: var(--space-lg);
  }

  .calendar-wrapper :global(.calendar-modal-title) {
    margin-right: 2rem;
  }
}
</style>
