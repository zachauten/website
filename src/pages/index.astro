---
import { sanityClient } from "sanity:client";
import Hero from "../components/Hero.astro";
import Layout from "../layouts/Layout.astro";
import { type Campaign } from "../sanity/schemaTypes/campaign";
import { type HomepageContent } from "../sanity/schemaTypes/homepageContent";
import { type ProgramItem } from "../sanity/schemaTypes/programItem";
import { type SocialMedia } from "../sanity/schemaTypes/socialMedia";

const homepage = await sanityClient.fetch<HomepageContent>(
  `*[_type == "homepageContent"][0]{
      hero,
      about,
      join
    }`,
);

const sortedProgram = await sanityClient.fetch<ProgramItem[]>(
  `*[_type == "programItem"] | order(order asc) {
    title,
    icon,
    description,
    order
  }`,
);

const sortedCampaigns = await sanityClient.fetch<Campaign[]>(
  `*[_type == "campaign"] | order(order asc) {
    title,
    description,
    order
  }`,
);

const socialMediaItems = await sanityClient.fetch<SocialMedia[]>(
  `*[_type == "socialMedia"] | order(order asc) {
    platform,
    label,
    url,
    emoji,
    order
  }`,
);
---

<Layout title="North Carolina DSA - Democratic Socialists of America">
  <Hero title={homepage.hero?.title} subtitle={homepage.hero?.subtitle} />
  <main id="main-content">
    <!-- About Section -->
    <section id="about" class="section section--slant-top">
      <div class="container">
        <div class="about-inner">
          <h2 class="section-heading">{homepage.about?.heading}</h2>
          <div class="about-text">
            <p class="lead-text">
              {homepage.about?.paragraph1}
            </p>
            <p>
              {homepage.about?.paragraph2}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Program Section -->
    <section id="program" class="section bg-light">
      <div class="container">
        <h2 class="section-heading section-heading--center">Our Program</h2>
        <div class="values-grid">
          {sortedProgram.map((item, i) => (
            <div
              class="card card--elevated value-card"
              style={`animation-delay: ${i * 80}ms`}
            >
              <span class="value-icon" aria-hidden="true">{item.icon}</span>
              <h3 class="value-title">{item.title}</h3>
              <p>{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Campaigns Section -->
    <section id="campaigns" class="section">
      <div class="container">
        <h2 class="section-heading">Our Campaigns</h2>
        <div class="campaigns-grid">
          {sortedCampaigns.map((campaign, i) => (
            <div
              class="card card--bordered campaign-card"
              style={`animation-delay: ${i * 80}ms`}
            >
              <h3 class="campaign-title">{campaign.title}</h3>
              <p>{campaign.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Join Section -->
    <section
      id="join"
      class="section bg-red section--slant-top section--slant-bottom"
    >
      <div class="container join-inner">
        <h2 class="section-heading section-heading--center">
          {homepage.join?.heading}
        </h2>
        <p class="join-text">
          {homepage.join?.text}
        </p>
        <div class="join-buttons">
          <a
            href="https://dsausa.org/join"
            class="btn btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >Join DSA</a>
          <a href="#contact" class="btn btn--outline">Contact NC Chapter</a>
        </div>
        {homepage.join?.duesInfo && (
          <p class="dues-info">
            {homepage.join?.duesInfo}
          </p>
        )}
      </div>
    </section>

    <!-- Events Section -->
    <section id="events" class="section section--slant-top">
      <div class="container events-cta">
        <h2 class="section-heading section-heading--center">Upcoming Events</h2>
        <p>
          Join us for meetings, actions, social events, and more! Check out our
          <a href="/calendar">full events calendar</a> to see what's happening.
        </p>
        <div class="events-btn-wrap">
          <a href="/calendar" class="btn btn--primary">View Calendar</a>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="section bg-light">
      <div class="container">
        <h2 class="section-heading">Get Involved</h2>
        <p>
          Want to learn more or get involved with North Carolina DSA? We'd love
          to hear from you!
        </p>
        <ul class="contact-list">
          {socialMediaItems.map((item) => {
            const isExternal = item.url.startsWith("http://")
              || item.url.startsWith("https://");

            return (
              <li class="contact-item">
                <span
                  class="contact-icon"
                  aria-hidden="true"
                >{item.emoji ? item.emoji : "🔗"}</span>
                <span class="contact-body">
                  <strong>{item.platform}</strong>
                  <a
                    href={item.url}
                    target={isExternal ? "_blank" : undefined}
                    rel={isExternal ? "noopener noreferrer" : undefined}
                  >
                    {item.label}
                    {isExternal && (
                      <svg
                        class="ext-icon"
                        width="12"
                        height="12"
                        viewBox="0 0 12 12"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        aria-hidden="true"
                      >
                        <path d="M4.5 1.5H10.5V7.5M10.5 1.5L1.5 10.5" />
                      </svg>
                    )}
                  </a>
                </span>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  </main>
</Layout>

<style>
main {
  min-height: 100vh;
}

/* --- About --- */
.about-inner {
  max-width: var(--max-width-narrow);
}

.about-text p {
  font-size: var(--text-md);
  line-height: 1.75;
  color: var(--text-secondary);
}

.lead-text {
  font-size: var(--text-lg);
  color: var(--text-primary);
  font-weight: 500;
  line-height: 1.65;
}

/* --- Values / Program Grid --- */
.values-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--space-lg);
  margin-top: var(--space-xl);
}

.value-card {
  text-align: center;
  padding: var(--space-xl) var(--space-lg);
  animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  border-top: 3px solid var(--red-primary);
  border-radius: 0 0 var(--radius-md) var(--radius-md);
}

.value-icon {
  font-size: var(--text-3xl);
  display: block;
  margin-bottom: var(--space-sm);
}

.value-title {
  color: var(--red-primary);
  font-size: var(--text-xl);
  margin-bottom: var(--space-xs);
}

.value-card p {
  color: var(--text-secondary);
  font-size: var(--text-sm);
  line-height: 1.65;
  max-width: none;
  margin: 0 auto;
}

/* --- Campaigns Grid --- */
.campaigns-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--space-lg);
  margin-top: var(--space-xl);
}

.campaign-card {
  padding: var(--space-xl);
  background: var(--gray-50);
  animation: slideInRight var(--duration-slow) var(--ease-out) both;
}

.campaign-title {
  color: var(--red-primary);
  font-size: var(--text-xl);
  margin-bottom: var(--space-sm);
}

.campaign-card p {
  color: var(--text-secondary);
  font-size: var(--text-sm);
  max-width: none;
}

/* --- Join Section --- */
.join-inner {
  text-align: center;
  max-width: 800px;
  margin: 0 auto;
}

#join {
  background: pink;
  color: var(--red-primary);
}

#join .section-heading,
#join .section-heading--center,
#join .section-heading--center::after {
  color: var(--red-primary);
}

#join .section-heading::after {
  background: var(--red-primary);
}

.join-text {
  font-size: var(--text-md);
  margin-bottom: var(--space-xl);
  max-width: 650px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.7;
  color: var(--red-primary);
}

.join-buttons {
  display: flex;
  gap: var(--space-md);
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: var(--space-lg);
}

.dues-info {
  font-style: italic;
  font-size: var(--text-sm);
  color: var(--red-dark);
  max-width: none;
}

#join .btn--outline {
  color: var(--red-primary);
  border-color: var(--red-primary);
}

#join .btn--outline:hover {
  background: var(--red-primary);
  color: var(--white);
  box-shadow: var(--shadow-lg);
}

/* --- Events CTA --- */
.events-cta {
  text-align: center;
  max-width: var(--max-width-narrow);
  margin: 0 auto;
}

.events-cta p {
  font-size: var(--text-md);
  color: var(--text-secondary);
  max-width: none;
  margin-bottom: var(--space-lg);
}

.events-btn-wrap {
  margin-top: var(--space-md);
}

/* --- Contact --- */
.contact-list {
  list-style: none;
  margin-top: var(--space-xl);
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: var(--space-md);
}

.contact-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-md);
  background: var(--white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition:
    transform var(--duration-fast) var(--ease-out),
    box-shadow var(--duration-normal) var(--ease-out);
}

.contact-item:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

.contact-icon {
  font-size: var(--text-xl);
  flex-shrink: 0;
  line-height: 1;
  margin-top: 2px;
}

.contact-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-3xs);
  font-size: var(--text-sm);
}

.contact-body strong {
  color: var(--text-primary);
  font-size: var(--text-sm);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  font-weight: 600;
}

.contact-body a {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2xs);
}

.ext-icon {
  opacity: 0.5;
  flex-shrink: 0;
}

/* --- Responsive --- */
@media (max-width: 1024px) {
  .campaigns-grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
}

@media (max-width: 768px) {
  .values-grid,
  .campaigns-grid {
    grid-template-columns: 1fr;
  }

  .contact-list {
    grid-template-columns: 1fr;
  }

  .join-buttons {
    flex-direction: column;
    align-items: center;
  }

  .join-buttons .btn {
    width: 100%;
    max-width: 300px;
  }
}
</style>
