---
import Layout from "../../layouts/Layout.astro";
import { loadQuery } from "../../sanity/lib/load-query";

interface PostListItem {
  title: string;
  slug: {
    current: string;
  };
  publishedAt?: string;
}

const { data: posts } = await loadQuery<PostListItem[]>({
  query: `*[_type == "post" && defined(slug.current)]
    | order(coalesce(publishedAt, _createdAt) desc){
      title,
      slug,
      publishedAt
    }`,
});
---

<Layout title="Left Angles | North Carolina DSA">
  <main id="main-content">
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="container">
        <h1>Left Angles</h1>
        <p class="page-hero-sub">
          News, analysis, and dispatches from NC Triangle DSA
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="posts-grid">
          {posts.map((post, i) => (
            <article
              class="card card--elevated post-card"
              style={`animation-delay: ${i * 60}ms`}
            >
              <a href={`/leftangles/${post.slug.current}`} class="post-link">
                <h2 class="post-title">{post.title}</h2>
                {post.publishedAt && (
                  <time class="post-meta" datetime={post.publishedAt}>
                    {new Date(post.publishedAt).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                )}
                <span class="post-arrow" aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
main {
  min-height: 100vh;
}

.page-hero {
  background: linear-gradient(
    160deg,
    var(--red-primary) 0%,
    var(--red-dark) 50%,
    var(--red-darker) 100%
  );
  color: var(--white);
  padding: var(--space-3xl) 0;
  text-align: center;
  position: relative;
  overflow: hidden;
  clip-path: polygon(0 0, 100% 0, 100% calc(100% - 30px), 0 100%);
}

.page-hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 40px,
    rgba(0, 0, 0, 0.04) 40px,
    rgba(0, 0, 0, 0.04) 42px
  );
  pointer-events: none;
}

.page-hero h1 {
  color: var(--white);
  position: relative;
}

.page-hero-sub {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  color: rgba(255, 255, 255, 0.9);
  max-width: 500px;
  margin: 0 auto;
  position: relative;
}

.posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--space-lg);
}

.post-card {
  padding: 0;
  border-top: 3px solid var(--red-primary);
  border-radius: 0 0 var(--radius-md) var(--radius-md);
  animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  overflow: hidden;
}

.post-link {
  display: flex;
  flex-direction: column;
  padding: var(--space-xl) var(--space-lg);
  text-decoration: none;
  color: inherit;
  height: 100%;
  position: relative;
}

.post-link:hover {
  text-decoration: none;
}

.post-link:hover .post-title {
  color: var(--red-primary);
}

.post-link:hover .post-arrow {
  transform: translateX(4px);
  opacity: 1;
}

.post-title {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  color: var(--text-primary);
  text-transform: uppercase;
  letter-spacing: 0.02em;
  margin-bottom: var(--space-xs);
  transition: color var(--duration-fast) var(--ease-out);
  line-height: 1.1;
}

.post-meta {
  color: var(--text-secondary);
  font-size: var(--text-sm);
  margin-top: auto;
}

.post-arrow {
  position: absolute;
  bottom: var(--space-lg);
  right: var(--space-lg);
  font-size: var(--text-lg);
  color: var(--red-primary);
  opacity: 0;
  transition:
    transform var(--duration-fast) var(--ease-out),
    opacity var(--duration-fast) var(--ease-out);
}

@media (max-width: 768px) {
  .posts-grid {
    grid-template-columns: 1fr;
  }
}
</style>
